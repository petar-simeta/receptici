---
import type { CollectionEntry } from "astro:content";
import { durationUpperBound, formatDuration, formatPrice, formatYieldUnit } from "../lib/format";
import TagBadge from "./TagBadge.astro";

interface Props {
  recipe: CollectionEntry<"recipes">;
}

const { recipe } = Astro.props;
const { data } = recipe;
const searchableIngredients = data.ingredients.map((ingredient) => ingredient.name).join(" ");
---

<article
  class="recipe-card"
  data-recipe-card
  data-title={data.title.toLocaleLowerCase("hr")}
  data-ingredients={searchableIngredients.toLocaleLowerCase("hr")}
  data-tags={data.tags.join("|")}
  data-duration={durationUpperBound(data.totalTime)}
  data-price={data.price}
  data-calories={data.calories}
>
  <a class="recipe-card__link" href={`/recipe/${recipe.id}`}>
    <div class="recipe-card__image">
      <img
        src={data.image}
        alt={data.imageAlt}
        width="1200"
        height="750"
        decoding="async"
      />
    </div>

    <div class="recipe-card__header">
      <h2>{data.title}</h2>
      <p>{data.subtitle}</p>
    </div>

    <div class="recipe-card__body">
      <div class="tag-list">
        {data.tags.map((tag) => <TagBadge tag={tag} />)}
      </div>

      <div class="recipe-card__details">
        <span title="Ukupno vrijeme">
          <svg viewBox="0 0 24 24" aria-hidden="true"><circle cx="12" cy="12" r="9" /><path d="M12 7v5l3 2" /></svg>
          {formatDuration(data.totalTime)}
        </span>
        <span title="Cijena po porciji">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M18 7.5a7 7 0 1 0 0 9M5 10h9M5 14h8" /></svg>
          {formatPrice(data.price)}
        </span>
        <span title="Kalorije">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 22c4 0 7-3 7-7 0-5-4-7-5-12-4 3-9 7-9 12 0 4 3 7 7 7Z" /><path d="M9 17c0 2 1 3 3 3s3-1 3-3-1-3-3-5c-1 2-3 3-3 5Z" /></svg>
          {data.calories} kcal
        </span>
        <span title="Broj osoba ili komada">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><circle cx="9" cy="7" r="4" /><path d="M22 21v-2a4 4 0 0 0-3-3.87M16 3.13a4 4 0 0 1 0 7.75" /></svg>
          {data.yield.amount} {formatYieldUnit(data.yield.amount, data.yield)}
        </span>
      </div>
    </div>
  </a>
</article>
