---
import ScaledValue from "./ScaledValue.astro";

interface Ingredient {
  name: string;
  quantity: string;
  scaled?: {
    value: number;
    unit: string;
    oneUnit?: string;
    fewUnit?: string;
    rounding: "smart" | "whole" | "half" | "tenth";
  };
}

interface Props {
  ingredients: Ingredient[];
}

const { ingredients } = Astro.props;
---

<div class="shopping-list" data-shopping-list>
  <button class="button button--outline shopping-list__trigger" type="button" data-shopping-open>
    <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M6 8h12l1 12H5L6 8Z" /><path d="M9 9V6a3 3 0 0 1 6 0v3" /></svg>
    Popis za kupnju
  </button>

  <dialog class="shopping-dialog" data-shopping-dialog aria-labelledby="shopping-title">
    <div class="shopping-dialog__header">
      <div>
        <h2 id="shopping-title">Popis za kupnju</h2>
        <p>Označiti ono što već imate. Kopirat će se samo neoznačeni sastojci.</p>
      </div>
      <button class="icon-button" type="button" aria-label="Zatvori popis" data-shopping-close>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="m6 6 12 12M18 6 6 18" /></svg>
      </button>
    </div>

    <div class="shopping-dialog__items">
      {ingredients.map((ingredient) => (
        <label class="shopping-item">
          <input type="checkbox" />
          <span class="shopping-item__text">
            <strong>{ingredient.name}</strong>
            {(ingredient.scaled || ingredient.quantity) && (
              <span>
                {" — "}
                {ingredient.scaled ? (
                  <ScaledValue
                    value={ingredient.scaled.value}
                    unit={ingredient.scaled.unit}
                    oneUnit={ingredient.scaled.oneUnit}
                    fewUnit={ingredient.scaled.fewUnit}
                    rounding={ingredient.scaled.rounding}
                  />
                ) : ingredient.quantity}
              </span>
            )}
          </span>
        </label>
      ))}
    </div>

    <div class="shopping-dialog__footer">
      <button class="button button--primary" type="button" data-shopping-copy>
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M20 6 9 17l-5-5" /></svg>
        <span>Kopiraj što nedostaje</span>
        <span class="shopping-copy-count" aria-hidden="true" data-shopping-copy-count></span>
      </button>
    </div>
  </dialog>

  <div class="toast" role="status" aria-live="polite" hidden data-shopping-toast></div>
</div>

<script>
  const root = document.querySelector<HTMLElement>("[data-shopping-list]");

  if (root) {
    const dialog = root.querySelector<HTMLDialogElement>("[data-shopping-dialog]");
    const open = root.querySelector<HTMLButtonElement>("[data-shopping-open]");
    const closeButtons = root.querySelectorAll<HTMLButtonElement>("[data-shopping-close]");
    const copy = root.querySelector<HTMLButtonElement>("[data-shopping-copy]");
    const copyCount = root.querySelector<HTMLElement>("[data-shopping-copy-count]");
    const checkboxes = [...root.querySelectorAll<HTMLInputElement>(".shopping-item input")];
    const toast = root.querySelector<HTMLElement>("[data-shopping-toast]");
    let toastTimer: number | undefined;

    const showToast = (message: string, isError = false) => {
      if (!toast) return;
      window.clearTimeout(toastTimer);
      toast.textContent = message;
      toast.classList.toggle("toast--error", isError);
      toast.hidden = false;
      toastTimer = window.setTimeout(() => {
        toast.hidden = true;
      }, 3000);
    };

    const updateCopyCount = () => {
      if (!copyCount) return;
      const missingCount = checkboxes.filter((checkbox) => !checkbox.checked).length;
      copyCount.textContent = `(${missingCount})`;
    };

    open?.addEventListener("click", () => dialog?.showModal());
    closeButtons.forEach((button) => button.addEventListener("click", () => dialog?.close()));
    dialog?.addEventListener("click", (event) => {
      if (event.target === dialog) dialog.close();
    });
    checkboxes.forEach((checkbox) => checkbox.addEventListener("change", updateCopyCount));
    updateCopyCount();

    copy?.addEventListener("click", async () => {
      const missing = [...root.querySelectorAll<HTMLLabelElement>(".shopping-item")]
        .filter((item) => !item.querySelector<HTMLInputElement>("input")?.checked)
        .map((item) => item.querySelector<HTMLElement>(".shopping-item__text")?.innerText.trim())
        .filter(Boolean)
        .join("\n");

      try {
        await navigator.clipboard.writeText(missing);
        dialog?.close();
        showToast(missing ? "Popis je kopiran." : "Sve sastojke već imate.");
      } catch {
        showToast("Kopiranje nije uspjelo.", true);
      }
    });
  }
</script>
