---
interface Props {
  activeCategory?: "meal" | "dessert";
  recipeLinks: string[];
}

const { activeCategory, recipeLinks } = Astro.props;
---

<header class="site-header">
  <div class="site-header__inner">
    <a class="brand" href="/" aria-label="Receptići — Obroci">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M12 16H4a2 2 0 1 1 0-4h16a2 2 0 1 1 0 4h-4.25" />
        <path d="M5 12a2 2 0 0 1-2-2 9 7 0 0 1 18 0 2 2 0 0 1-2 2" />
        <path d="M5 16a2 2 0 0 0-2 2 3 3 0 0 0 3 3h12a3 3 0 0 0 3-3 2 2 0 0 0-2-2" />
        <path d="m6.67 12 6.13 4.6a2 2 0 0 0 2.8-.4l3.15-4.2" />
      </svg>
      <span>Receptići</span>
    </a>

    <nav class="category-nav" aria-label="Glavne kategorije">
      <a href="/" aria-current={activeCategory === "meal" ? "page" : undefined}>Obroci</a>
      <a
        href="/slastice"
        aria-current={activeCategory === "dessert" ? "page" : undefined}
      >Slastice</a>
    </nav>

    <button class="icon-button random-recipe" type="button" aria-label="Nasumični recept" title="Nasumični recept">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path d="M16 3h5v5M4 20 21 3M21 16v5h-5M15 15l6 6M4 4l5 5" />
      </svg>
    </button>
  </div>
</header>

<script is:inline define:vars={{ recipeLinks }}>
  const randomButton = document.querySelector(".random-recipe");

  randomButton?.addEventListener("click", () => {
    if (!recipeLinks.length) return;

    const currentPath = window.location.pathname;
    const candidates = recipeLinks.filter((link) => link !== currentPath);
    const pool = candidates.length ? candidates : recipeLinks;
    const nextRecipe = pool[Math.floor(Math.random() * pool.length)];
    window.location.assign(nextRecipe);
  });
</script>
